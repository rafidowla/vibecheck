# OpenRouter API key — required for AI-powered report generation
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use for vision analysis (default: Qwen multimodal)
OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct

# Whisper model size: base, small, medium-q5, medium, large-v3-q5, large-v3
# medium-q5 is recommended: good multilingual accuracy, low memory (~1 GB)
WHISPER_MODEL=medium-q5

# Output directory (default: ~/Downloads/vibecheck-output)
# OUTPUT_DIR=~/Downloads/vibecheck-output

# ---------------------------------------------------------------------------
# Jira Integration (optional — leave commented out to disable)
# ---------------------------------------------------------------------------

# Jira Cloud base URL (do NOT include trailing slash)
# JIRA_BASE_URL=https://yourorg.atlassian.net

# Atlassian account email
# JIRA_EMAIL=you@yourorg.com

# Jira API token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
# JIRA_API_TOKEN=your-api-token-here

# Target project key (e.g. PROJ, QA, DEV)
# JIRA_PROJECT_KEY=PROJ

# Issue type to create (default: Task)
# JIRA_ISSUE_TYPE=Task
