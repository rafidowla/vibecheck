# OpenRouter API key — required for AI-powered report generation
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use for vision analysis (default: Qwen multimodal)
OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct

# Whisper model size: base, small, medium-q5, medium, large-v3-q5, large-v3
# medium-q5 is recommended: good multilingual accuracy, low memory (~1 GB)
WHISPER_MODEL=medium-q5

# Output directory (default: ~/Downloads/vibecheck-output)
# OUTPUT_DIR=~/Downloads/vibecheck-output
